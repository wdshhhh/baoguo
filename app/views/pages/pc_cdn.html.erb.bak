                    onmouseover: (e) => e.target.style.background = '#67a5ff',
                    onmouseout: (e) => e.target.style.background = '#409EFF'
                  }, '📤 上传图片识别')
                ]),
                Vue.h('div', { style: 'display:flex;gap:30px;' }, [
                  Vue.h('div', { style: 'flex:1;' }, [
                    Vue.h('h4', { style: 'font-size:14px;color:#303133;margin-bottom:15px;' }, '识别结果'),
                    ocrResult.value ? Vue.h('div', { style: 'border:1px solid #e4e7ed;border-radius:4px;padding:20px;' }, [
                      Vue.h('div', { style: 'display:grid;grid-template-columns:1fr 1fr;gap:15px;' }, [
                        Vue.h('div', [
                          Vue.h('span', { style: 'color:#909399;font-size:14px;' }, '运单号：'),
                          Vue.h('span', { style: 'color:#303133;font-size:14px;' }, ocrResult.value.tracking_number)
                        ]),
                        Vue.h('div', [
                          Vue.h('span', { style: 'color:#909399;font-size:14px;' }, '收件人：'),
                          Vue.h('span', { style: 'color:#303133;font-size:14px;' }, ocrResult.value.recipient_name)
                        ]),
                        Vue.h('div', [
                          Vue.h('span', { style: 'color:#909399;font-size:14px;' }, '手机号：'),
                          Vue.h('span', { style: 'color:#303133;font-size:14px;' }, ocrResult.value.recipient_phone)
                        ]),
                        Vue.h('div', [
                          Vue.h('span', { style: 'color:#909399;font-size:14px;' }, '快递公司：'),
                          Vue.h('span', { style: 'color:#303133;font-size:14px;' }, ocrResult.value.courier_company)
                        ]),
                        Vue.h('div', [
                          Vue.h('span', { style: 'color:#909399;font-size:14px;' }, '重量：'),
                          Vue.h('span', { style: 'color:#303133;font-size:14px;' }, ocrResult.value.weight + ' kg')
                        ]),
                        Vue.h('div', { style: 'grid-column:1/-1;' }, [
                          Vue.h('span', { style: 'color:#909399;font-size:14px;' }, '地址：'),
                          Vue.h('span', { style: 'color:#303133;font-size:14px;' }, ocrResult.value.recipient_address)
                        ])
                      ]),
                      Vue.h('div', { style: 'margin-top:20px;display:flex;gap:10px;' }, [
                        Vue.h('button', {
                          onClick: createPackageFromOCR,
                          disabled: ocrLoading,
                          style: 'padding:8px 16px;border:none;border-radius:4px;background:#67C23A;color:white;font-size:14px;cursor:pointer;',
                          onmouseover: (e) => e.target.style.background = '#85ce61',
                          onmouseout: (e) => e.target.style.background = '#67C23A'
                        }, '📦 创建包裹'),
                        Vue.h('button', {
                          onClick: () => { ocrResult.value = null },
                          style: 'padding:8px 16px;border:none;border-radius:4px;background:#f5f7fa;color:#606266;font-size:14px;cursor:pointer;',
                          onmouseover: (e) => e.target.style.background = '#e4e7ed',
                          onmouseout: (e) => e.target.style.background = '#f5f7fa'
                        }, '清空')
                      ])
                    ]) : Vue.h('div', { style: 'border:2px dashed #dcdfe6;border-radius:4px;padding:60px;text-align:center;' }, [
                      Vue.h('div', { style: 'font-size:48px;margin-bottom:15px;' }, '📷'),
                      Vue.h('p', { style: 'color:#909399;font-size:14px;' }, '请点击上方按钮上传图片进行OCR识别')
                    ])
                  ]),
                  Vue.h('div', { style: 'width:400px;' }, [
                    Vue.h('h4', { style: 'font-size:14px;color:#303133;margin-bottom:15px;' }, '识别历史'),
                    Vue.h('div', { style: 'border:1px solid #e4e7ed;border-radius:4px;max-height:400px;overflow:auto;' }, [
                      Vue.h('div', { style: 'padding:10px;color:#909399;font-size:14px;text-align:center;' }, '暂无识别记录')
                    ])
                  ])
                ])
              ])
            ])
          ])
        ])
      }}).mount('#app')
</script>