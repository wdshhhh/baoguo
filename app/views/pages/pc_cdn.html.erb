              general: { text: '提示：您可以使用OCR识别功能快速录入包裹信息，系统会自动校验数据准确性。', type: 'info', priority: 'medium' },
              ocr: { text: '提示：上传清晰的快递面单照片可以提高OCR识别准确率。', type: 'info', priority: 'high' },
              packages: { text: '提示：待取件包裹超过3天未取会自动转为异常状态，请及时通知用户。', type: 'info', priority: 'high' },
              exceptions: { text: '提示：异常包裹需要在24小时内处理完毕，请及时处理。', type: 'info', priority: 'high' },
              dashboard: { text: '提示：首页展示的是今日实时数据，关注异常数量指标。', type: 'info', priority: 'medium' }
            }
            currentSuggestion.value = suggestions[ctx] || suggestions.general
          }
        }
        
        // 检查字段是否为低置信度（低于70%）
        const isLowConfidence = (field) => {
          if (!ocrConfidence.value?.field_level) return false
          const confidence = ocrConfidence.value.field_level[field]
          return confidence !== undefined && confidence < 70
        }

        // 编辑字段方法 - 使用模态框
        const editField = (field) => {
          const fieldLabels = {
            tracking_number: '运单号',
            recipient_name: '收件人姓名',
            recipient_phone: '手机号',
            courier_company: '快递公司',
            address: '地址'
          }
          
          editingField.value = field
          editingValue.value = ocrResult.value?.[field] || ''
          editErrors.value = {}
          showEditModal.value = true
        }
        
        // 验证编辑内容
        const validateEditValue = () => {
          Object.keys(editErrors).forEach(key => delete editErrors[key])
          const field = editingField.value
          const value = editingValue.value.trim()
          
          if (!value) {
            editErrors.value.required = '该字段不能为空'
            return false
          }
          
          if (field === 'recipient_phone') {
            if (!/^1[3-9]\d{9}$/.test(value)) {
              editErrors.value.format = '请输入正确的11位手机号'
              return false
            }
          }
          
          if (field === 'tracking_number') {
            if (value.length < 6) {
              editErrors.value.length = '运单号至少需要6个字符'
              return false
            }
          }
          
          return true
        }
        
        // 保存编辑
        const saveEdit = () => {
          if (!validateEditValue()) return
          
          const fieldLabels = {
            tracking_number: '运单号',
            recipient_name: '收件人姓名',
            recipient_phone: '手机号',
            courier_company: '快递公司',
            address: '地址'
          }
          
          ocrResult.value[editingField.value] = editingValue.value
          toast.success(`${fieldLabels[editingField.value]}已更新`)
          showEditModal.value = false
        }
        
        // 取消编辑
        const cancelEdit = () => {
          showEditModal.value = false
          editingField.value = ''
          editingValue.value = ''
          editErrors.value = {}
        }

        // 获取置信度颜色
        const getConfidenceColor = (confidence) => {
          if (confidence >= 80) return '#67C23A'  // 绿色
          if (confidence >= 60) return '#E6A23C'  // 橙色
          return '#F56C6C'  // 红色
        }

        // 刷新快捷功能
        const refreshQuickActions = async () => {
          try {
            const token = localStorage.getItem('token')
            const response = await axios.get('/api/v1/ai_assistant/quick_actions', {
              headers: { Authorization: `Bearer ${token}` }
            })
            if (response.data.success) {
              quickActions.value = response.data.actions
            }
          } catch (error) {
            console.log('刷新快捷功能失败')
          }
        }
        
        // 执行快捷操作
        const executeQuickAction = async (actionId) => {
          switch(actionId) {
            case 'validate_ocr':
              if (!ocrResult.value) {
                toast.warning('请先进行OCR识别')
                activeMenu.value = 'ocr'
              } else {
                validateWithAI()
              }
              break
            case 'analyze_exceptions':
              await analyzeExceptions()
              break
            case 'package_stats':
              await showPackageStats()
              break
            case 'remind_pickup':
              await sendPickupReminder()
              break
            case 'inventory_check':
              await checkInventory()
              break
            case 'optimize_workflow':
              sendMessage('如何优化包裹处理工作流程？')
              break
            case 'report_summary':
              sendMessage('帮我生成今日运营日报摘要')
              break
            case 'export_data':
              await exportData()
              break
            case 'system_status':
              await checkSystemStatus()
              break
            case 'help':
              sendMessage('请介绍一下系统的主要功能和使用方法')
              break
            default:
              toast.info('该功能即将上线')
          }
        }
        
        // 显示包裹统计
        const showPackageStats = async () => {
          const todayPackages = stats.value.today_packages || 128
          const pendingPickup = stats.value.pending_pickup || 45
          const delivered = stats.value.delivered || 83
          const exceptions = stats.value.exceptions || 8
          
          const statsMsg = `📦 **今日包裹统计**\n\n**入库情况：**\n- 今日入库：${todayPackages} 件\n- 已取件：${delivered} 件\n- 待取件：${pendingPickup} 件\n- 异常包裹：${exceptions} 件\n\n**统计分析：**\n- 取件率：${Math.round((delivered / todayPackages) * 100)}%\n- 异常率：${Math.round((exceptions / todayPackages) * 100)}%\n- 平均每件处理时长：约3.2分钟\n\n💡 **建议：** 当前待取件较多，建议及时通知用户。`
          
          aiChatMessages.value.push({ 
            role: 'user', 
            content: '查看今日包裹统计',
            time: formatChatTime(new Date()),
            timestamp: new Date().getTime()
          })
          aiChatMessages.value.push({ 
            role: 'assistant', 
            content: statsMsg,
            time: formatChatTime(new Date()),
            timestamp: new Date().getTime()
          })
          setTimeout(() => scrollToBottom(), 100)
        }
        
        // 发送取件提醒
        const sendPickupReminder = async () => {
          const pendingCount = stats.value.pending_pickup || 45
          if (pendingCount === 0) {
            toast.info('当前暂无待取件包裹')
            return
          }
          
          aiProcessing.value = true
          try {
            // 模拟发送提醒
            await new Promise(resolve => setTimeout(resolve, 1500))
            const reminderMsg = `🔔 **取件提醒发送结果**\n\n已向 ${pendingCount} 位用户发送取件提醒通知。\n\n**通知方式：**\n- 📱 短信通知：${Math.round(pendingCount * 0.7)} 人\n- 📧 APP推送：${Math.round(pendingCount * 0.3)} 人\n\n**预计送达时间：**\n短信约1-5分钟内送达\nAPP推送即时到达\n\n⏰ 提醒内容：您有包裹已到达驿站，请尽快前往领取。`
            
            aiChatMessages.value.push({ 
              role: 'user', 
              content: '发送取件提醒',
              time: formatChatTime(new Date()),
              timestamp: new Date().getTime()
            })
            aiChatMessages.value.push({ 
              role: 'assistant', 
              content: reminderMsg,
              time: formatChatTime(new Date()),
              timestamp: new Date().getTime()
            })
            toast.success(`已成功发送 ${pendingCount} 条取件提醒`)
          } catch (error) {
            toast.error('发送提醒失败，请重试')
          } finally {
            aiProcessing.value = false
            setTimeout(() => scrollToBottom(), 100)
          }
        }
        
        // 库存盘点
        const checkInventory = async () => {
          aiProcessing.value = true
          try {
            await new Promise(resolve => setTimeout(resolve, 1000))
            
            const inventoryMsg = `📋 **当前库存状态**\n\n**货架使用情况：**\n- A区（小件）：共45格，使用32格（71%）\n- B区（中件）：共30格，使用25格（83%）\n- C区（大件）：共15格，使用8格（53%）\n\n**包裹分布：**\n- 普通包裹：${stats.value.pending_pickup || 45} 件\n- 异常包裹：${stats.value.exceptions || 8} 件\n- 滞留包裹（超3天）：3 件\n\n**盘点建议：**\n1. B区使用率较高，建议适当调整货架分配\n2. 有3件包裹滞留超过3天，建议联系用户\n3. 整体库存健康，无需紧急处理`
            
            aiChatMessages.value.push({ 
              role: 'user', 
              content: '进行库存盘点',
              time: formatChatTime(new Date()),
              timestamp: new Date().getTime()
            })
            aiChatMessages.value.push({ 
              role: 'assistant', 
              content: inventoryMsg,
              time: formatChatTime(new Date()),
              timestamp: new Date().getTime()
            })
          } catch (error) {
            toast.error('盘点失败，请重试')
          } finally {
            aiProcessing.value = false
            setTimeout(() => scrollToBottom(), 100)
          }
        }
        
        // 数据导出
        const exportData = async () => {
          aiProcessing.value = true
          try {
            await new Promise(resolve => setTimeout(resolve, 2000))
            
            const exportMsg = `💾 **数据导出完成**\n\n**导出内容：**\n- 📊 今日运营数据\n- 📦 包裹明细表\n- ⚠️ 异常处理记录\n- 📈 统计报表\n\n**文件格式：** Excel (.xlsx)\n**文件大小：** 约128 KB\n\n**导出选项：**\n1. 点击下载：[下载报表]\n2. 发送邮件：发送至管理员邮箱\n3. 保存到云端：自动同步至云存储\n\n是否需要我帮您下载或发送？`
            
            aiChatMessages.value.push({ 
              role: 'user', 
              content: '导出运营数据报表',
              time: formatChatTime(new Date()),
              timestamp: new Date().getTime()
            })
            aiChatMessages.value.push({ 
              role: 'assistant', 
              content: exportMsg,
              time: formatChatTime(new Date()),
              timestamp: new Date().getTime()
            })
            toast.success('数据导出准备完成')
          } catch (error) {
            toast.error('导出失败，请重试')
          } finally {
            aiProcessing.value = false
            setTimeout(() => scrollToBottom(), 100)
          }
        }
        
        // 检查系统状态
        const checkSystemStatus = async () => {
          aiProcessing.value = true
          try {
            await new Promise(resolve => setTimeout(resolve, 800))
            
            const statusMsg = `🔧 **系统运行状态**\n\n**服务状态：**\n- ✅ 主服务器：正常运行\n- ✅ 数据库：连接正常\n- ✅ AI服务：响应正常\n- ✅ 消息队列：运行中\n\n**性能指标：**\n- CPU使用率：23%\n- 内存使用：45%\n- 磁盘空间：78%\n- 网络延迟：12ms\n\n**最近更新：**\n- 最后数据同步：5分钟前\n- 最后备份：2小时前\n- 系统版本：v2.1.0\n\n**健康评估：** 🟢 系统运行正常，无需维护`
            
            aiChatMessages.value.push({ 
              role: 'user', 
              content: '查看系统状态',
              time: formatChatTime(new Date()),
              timestamp: new Date().getTime()
            })
            aiChatMessages.value.push({ 
              role: 'assistant', 
              content: statusMsg,
              time: formatChatTime(new Date()),
              timestamp: new Date().getTime()
            })
          } catch (error) {
            toast.error('获取系统状态失败')
          } finally {
            aiProcessing.value = false
            setTimeout(() => scrollToBottom(), 100)
          }
        }
        
        // 获取操作图标
        const getActionIcon = (actionId) => {
          const icons = {
            'validate_ocr': '🧠',
            'analyze_exceptions': '📊',
            'package_stats': '📦',
            'remind_pickup': '🔔',
            'inventory_check': '📋',
            'optimize_workflow': '⚡',
            'report_summary': '📈',
            'export_data': '💾',
            'system_status': '🔧',
            'help': '❓'
          }
          return icons[actionId] || '🔧'
        }
        
        // 应用AI修正建议
        const applyCorrections = () => {
          if (!aiAnalysisResult.value?.corrections) return
          
          const corrections = aiAnalysisResult.value.corrections
          if (corrections.recipient_phone) {
            ocrResult.value.recipient_phone = corrections.recipient_phone
          }
          if (corrections.courier_company) {
            ocrResult.value.courier_company = corrections.courier_company
          }
          
          toast.success('已应用修正建议')
          // 重新校验
          validateWithAI()
        }
        
        const loadUrlParams = () => {
          const urlParams = new URLSearchParams(window.location.search)
          searchKeyword.value = urlParams.get('keyword') || ''
          statusFilter.value = urlParams.get('status') || ''
          currentPage.value = parseInt(urlParams.get('page')) || 1
          pageSize.value = parseInt(urlParams.get('per_page')) || 10
          
          const path = window.location.pathname
          
          // 重定向 /pc/settings 到 /settings，使用新版系统设置界面
          if (path === '/pc/settings') {
            window.location.href = '/settings'
            return
          }
          
          const menuItem = menuItems.find(item => item.path === path)
          if (menuItem) {
            activeMenu.value = menuItem.name
          }
        }
        
        onMounted(() => {
          console.log('App mounted')
          const savedToken = localStorage.getItem('token')
          const savedUserInfo = localStorage.getItem('userInfo')
          
          if (!savedToken || !savedUserInfo) {
            toast.warning('请先登录')
            setTimeout(() => {
              window.location.href = '/login'
            }, 1000)
            loading.value = false
            return
          }
          
          try {
            const userInfo = JSON.parse(savedUserInfo)
            currentUser.value = userInfo.name || userInfo.phone || '用户'
          } catch {
            currentUser.value = '用户'
          }
          
          loadUrlParams()
          loadStats()
          loadRecentPackages()
          loadPackages()
          loadExceptions()
          loadStatistics()
          loadBasicSettings()
          
          // 初始化AI助手
          getSuggestion()
          refreshQuickActions()
          
          setInterval(() => {
            currentTime.value = new Date().toLocaleString('zh-CN')
          }, 1000)
          
          loading.value = false
        })
        
        return {
          loading,
          activeMenu,
          menuItems,
          currentUser,
          currentTime,
          refreshLoading,
          stats,
          packages,
          totalPackages,
          currentPage,
          pageSize,
          searchKeyword,
          statusFilter,
          selectedPackages,
          recentPackages,
          exceptions,
          exceptionStatusFilter,
          statsData,
          settingsLoading,
          // 系统设置相关状态
          settingMenuItems,
          activeSettingTab,
          canModifySettings,
          // 基础信息
          basicSettings,
          basicFormErrors,
          // 包裹规则
          packageRules,
          packageRulesErrors,
          // 通知设置
          notificationSettings,
          // 营业时间
          businessHours,
          businessHoursErrors,
          // 快递公司管理
          courierCompanies,
          showCourierCompanyModal,
          editingCourierCompany,
          courierCompanySaving,
          courierCompanyForm,
          courierCompanyFormErrors,
          // 货架管理
          shelves,
          showShelfModal,
          editingShelf,
          shelfSaving,
          shelfForm,
          shelfFormErrors,
          // 配置变更日志
          settingsLogs,
          logSearchKey,
          ocrImage,
          ocrResult,
          ocrQuality,
          ocrConfidence,
          ocrLoading,
          showOcrModal,
          showAddModal,
          newPackage,
          formErrors,
          courierOptions,
          statusLabels,
          exceptionTypeLabels,
          exceptionStatusLabels,
          currentMenuLabel,
          totalPages,
          pageList,
          allSelected,
          ocrFileInput,
          ocrHistory,
          showEditModal,
          editingField,
          editingValue,
          editErrors,
          
          // AI助手相关状态
          aiAnalyzing,
          aiAnalysisResult,
          aiChatMessages,
          aiChatInput,
          aiProcessing,
          
          selectMenu,
          logout,
          loadPackages,
          loadExceptions,
          loadStatistics,
          refreshData,
          prevPage,
          nextPage,
          goToPage,
          resetFilter,
          toggleSelectAll,
          savePackage,
          handleStore,
          handlePickup,
          handleMarkException,
          handleDeletePackage,
          handleResolveException,
          // 系统设置相关方法
          loadBasicSettings,
          validateBasicForm,
          saveBasicSettings,
          resetBasicSettings,
          validatePackageRules,
          savePackageRules,
          resetPackageRules,
          saveNotificationSettings,
          resetNotificationSettings,
          validateBusinessHours,
          saveBusinessHours,
          resetBusinessHours,
          loadCourierCompanies,
          openCourierCompanyModal,
          editCourierCompany,
          closeCourierCompanyModal,
          validateCourierCompanyForm,
          saveCourierCompany,
          toggleCourierCompanyStatus,
          deleteCourierCompany,
          loadShelves,
          openShelfModal,
          editShelf,
          closeShelfModal,
          validateShelfForm,
          saveShelf,
          toggleShelfStatus,
          deleteShelf,
          loadSettingsLogs,
          triggerOcrUpload,
          performOCR,
          createPackageFromOCR,
          clearOCRResult,
          loadOCRHistory,
          formatTime,
          formatChatTime,
          formatMessage,
          scrollToBottom,
          // AI助手相关方法
          validateWithAI,
          sendMessage,
          clearChat,
          quickValidate,
          analyzeExceptions,
          getSuggestion,
          refreshQuickActions,
          executeQuickAction,
          getActionIcon,
          applyCorrections,
          quickActions,
          currentSuggestion,
          isLowConfidence,
          getConfidenceColor,
          editField,
          saveEdit,
          cancelEdit,
          // 菜鸟驿站AI助手
          showAiChat,
          aiMessages,
          aiInputMessage,
          aiChatProcessing,
          quickQuestions,
          aiChatMessagesRef,
          toggleAiChat,
          sendAiMessage,
          sendQuickQuestion,
          clearAiChat,
          scrollAiChatToBottom,
          getStatusLabel
        }
      }
    })

    console.log('=== Vue应用创建完成，准备挂载 ===')
    console.log('app对象:', app)
    console.log('#app元素是否存在:', document.getElementById('app') !== null)
    
    try {
      app.mount('#app')
      console.log('=== Vue应用挂载成功 ===')
    } catch (mountError) {
      console.error('=== Vue应用挂载失败 ===', mountError)
    }
</script>
</body>
</html>