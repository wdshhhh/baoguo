        // 添加识别历史
        const addToOCRHistory = (data) => {
          const historyItem = {
            tracking_number: data.tracking_number,
            recipient_name: data.recipient_name,
            recipient_phone: data.recipient_phone,
            courier_company: data.courier_company,
            address: data.address || '',
