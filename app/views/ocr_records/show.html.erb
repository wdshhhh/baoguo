<!DOCTYPE html>
<html>
<head>
  <title>OCR识别结果</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f5f7fa; padding: 20px; }
    .container { max-width: 1200px; margin: 0 auto; }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      flex-wrap: wrap;
      gap: 15px;
    }
    .header h1 { color: #2c3e50; }
    .back-link { color: #3498db; text-decoration: none; font-size: 16px; }
    .back-link:hover { text-decoration: underline; }

    .engine-selector {
      background: white;
      padding: 20px;
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.1);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 15px;
      flex-wrap: wrap;
    }
    .engine-label { font-weight: 600; color: #2c3e50; }
    .engine-buttons { display: flex; gap: 10px; }
    .engine-btn {
      padding: 8px 16px;
      border: 2px solid #e0e0e0;
      border-radius: 20px;
      background: white;
      cursor: pointer;
      transition: all 0.3s;
      font-size: 14px;
    }
    .engine-btn:hover { border-color: #3498db; }
    .engine-btn.active {
      background: #3498db;
      color: white;
      border-color: #3498db;
    }

    .status-badge {
      display: inline-block;
      padding: 6px 16px;
      border-radius: 20px;
      font-size: 14px;
      font-weight: 500;
    }
    .status-pending { background: #f39c12; color: white; }
    .status-processing { background: #3498db; color: white; }
    .status-recognized { background: #27ae60; color: white; }
    .status-corrected { background: #9b59b6; color: white; }
    .status-failed { background: #e74c3c; color: white; }

    .content-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    @media (max-width: 768px) { .content-grid { grid-template-columns: 1fr; } }

    .card {
      background: white;
      border-radius: 12px;
      padding: 24px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.1);
    }
    .card h2 { color: #2c3e50; margin-bottom: 20px; font-size: 20px; border-bottom: 2px solid #ecf0f1; padding-bottom: 10px; }

    .image-preview { width: 100%; border-radius: 8px; margin-bottom: 15px; }
    .image-info { color: #7f8c8d; font-size: 14px; line-height: 1.8; }

    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; color: #2c3e50; font-weight: 500; }
    .form-group input, .form-group textarea, .form-group select {
      width: 100%;
      padding: 12px;
      border: 2px solid #ecf0f1;
      border-radius: 8px;
      font-size: 16px;
      transition: border-color 0.3s;
    }
    .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
      outline: none;
      border-color: #3498db;
    }
    .form-group .field-hint { font-size: 12px; color: #95a5a6; margin-top: 4px; }

    .confidence-bar {
      margin-top: 8px;
      height: 8px;
      background: #ecf0f1;
      border-radius: 4px;
      overflow: hidden;
    }
    .confidence-fill {
      height: 100%;
      border-radius: 4px;
      transition: width 0.3s;
    }
    .confidence-high { background: #27ae60; }
    .confidence-medium { background: #f39c12; }
    .confidence-low { background: #e74c3c; }

    .btn-group { display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap; }
    .btn {
      padding: 12px 24px;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      transition: all 0.3s;
    }
    .btn-primary { background: #3498db; color: white; }
    .btn-primary:hover { background: #2980b9; }
    .btn-success { background: #27ae60; color: white; }
    .btn-success:hover { background: #219a52; }
    .btn-danger { background: #e74c3c; color: white; }
    .btn-danger:hover { background: #c0392b; }
    .btn-secondary { background: #95a5a6; color: white; }
    .btn-secondary:hover { background: #7f8c8d; }

    .raw-text {
      background: #f8f9fa;
      padding: 16px;
      border-radius: 8px;
      font-family: monospace;
      white-space: pre-wrap;
      max-height: 300px;
      overflow-y: auto;
      font-size: 13px;
      line-height: 1.6;
    }

    .loading { text-align: center; padding: 60px 20px; }
    .spinner {
      border: 4px solid #f3f3f3;
      border-top: 4px solid #3498db;
      border-radius: 50%;
      width: 40px;
      height: 40px;
      animation: spin 1s linear infinite;
      margin: 0 auto 20px;
    }
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .flash { padding: 15px; border-radius: 8px; margin-bottom: 20px; }
    .flash.alert { background: #fee; color: #c33; border: 1px solid #fcc; }
    .flash.notice { background: #efe; color: #3c3; border: 1px solid #cfc; }

    .error-box {
      background: #fee;
      padding: 16px;
      border-radius: 8px;
      border-left: 4px solid #e74c3c;
      margin-bottom: 20px;
    }
    .error-title { color: #e74c3c; font-weight: 600; margin-bottom: 8px; }
    .error-message { color: #c33; }
  </style>
</head>
<body>
  <div class="container">
    <% if flash[:alert] %>
      <div class="flash alert"><%= flash[:alert] %></div>
    <% end %>
    <% if flash[:notice] %>
      <div class="flash notice"><%= flash[:notice] %></div>
    <% end %>

    <div class="header">
      <div>
        <h1>📋 OCR识别结果</h1>
        <span class="status-badge status-<%= @ocr_record.status %>">
          <%= @ocr_record.status.humanize %>
        </span>
      </div>
      <a href="<%= ocr_records_path %>" class="back-link">← 返回列表</a>
    </div>

    <!-- 引擎选择器 -->
    <div class="engine-selector">
      <span class="engine-label">当前OCR引擎:</span>
      <div class="engine-buttons">
        <% @available_engines.each do |engine| %>
          <%= button_to engine, switch_engine_ocr_records_path(engine: engine), 
              method: :post, 
              class: "engine-btn #{@current_engine == engine ? 'active' : ''}" %>
        <% end %>
      </div>
    </div>

    <% if @ocr_record.failed? && @ocr_record.error_message.present? %>
      <div class="error-box">
        <div class="error-title">❌ 识别失败</div>
        <div class="error-message"><%= @ocr_record.error_message %></div>
      </div>
    <% end %>

    <% if @ocr_record.pending? || @ocr_record.processing? %>
      <div class="loading">
        <div class="spinner"></div>
        <h3>正在识别中，请稍候...</h3>
        <p>页面将在3秒后自动刷新</p>
      </div>

      <script>
        setTimeout(() => location.reload(), 3000);
      </script>
    <% end %>

    <div class="content-grid">
      <!-- 左侧：图片预览 -->
      <div class="card">
        <h2>📷 面单图片</h2>
        <img src="<%= @ocr_record.image_url %>" class="image-preview" alt="面单图片">
        <div class="image-info">
          <p><strong>文件名:</strong> <%= @ocr_record.image_file_name %></p>
          <p><strong>大小:</strong> <%= number_to_human_size(@ocr_record.image_file_size) %></p>
          <% if @ocr_record.processing_time.present? %>
            <p><strong>识别耗时:</strong> <%= "%.2f" % @ocr_record.processing_time %> 秒</p>
          <% end %>
          <p><strong>置信度:</strong> <%= (@ocr_record.confidence_score * 100).to_i %>%</p>
          <div class="confidence-bar">
            <div class="confidence-fill <%= confidence_class(@ocr_record.confidence_score) %>" 
                 style="width: <%= @ocr_record.confidence_score * 100 %>%"></div>
          </div>
        </div>
      </div>

      <!-- 右侧：识别结果编辑 -->
      <div class="card">
        <h2>✏️ 识别结果</h2>

        <%= form_for @ocr_record do |f| %>
          <div class="form-group">
            <label>🏷️ 运单号</label>
            <%= f.text_field :tracking_number, placeholder: '请输入或修改运单号' %>
          </div>

          <div class="form-group">
            <label>👤 收件人姓名</label>
            <%= f.text_field :recipient_name, placeholder: '请输入收件人姓名' %>
          </div>

          <div class="form-group">
            <label>📱 收件人电话</label>
            <%= f.text_field :recipient_phone, placeholder: '请输入收件人电话' %>
          </div>

          <div class="form-group">
            <label>🏪 快递公司</label>
            <%= f.text_field :courier_company, placeholder: '请输入快递公司' %>
          </div>

          <div class="form-group">
            <label>📍 省</label>
            <%= f.text_field :recipient_province, placeholder: '请输入省份' %>
          </div>

          <div class="form-group">
            <label>🏙️ 市</label>
            <%= f.text_field :recipient_city, placeholder: '请输入城市' %>
          </div>

          <div class="form-group">
            <label>🏘️ 区</label>
            <%= f.text_field :recipient_district, placeholder: '请输入区县' %>
          </div>

          <div class="form-group">
            <label>🏠 详细地址</label>
            <%= f.text_area :recipient_address, placeholder: '请输入详细地址', rows: 3 %>
          </div>

          <div class="form-group">
            <label>📤 寄件人姓名</label>
            <%= f.text_field :sender_name, placeholder: '请输入寄件人姓名' %>
          </div>

          <div class="form-group">
            <label>📞 寄件人电话</label>
            <%= f.text_field :sender_phone, placeholder: '请输入寄件人电话' %>
          </div>

          <div class="btn-group">
            <%= f.submit '保存修改', class: 'btn btn-primary' %>

            <% if @ocr_record.successfully_recognized? %>
              <%= button_to '重新识别', recognize_ocr_record_path(@ocr_record), 
                  method: :post, 
                  class: 'btn btn-secondary' %>
            <% elsif @ocr_record.failed? %>
              <%= button_to '重新识别', recognize_ocr_record_path(@ocr_record), 
                  method: :post, 
                  class: 'btn btn-success' %>
            <% end %>

            <%= button_to '删除记录', @ocr_record, 
                method: :delete, 
                data: { confirm: '确定要删除这条记录吗?' },
                class: 'btn btn-danger' %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 原始识别文本 -->
    <% if @ocr_record.raw_text.present? %>
      <div class="card" style="margin-top: 20px;">
        <h2>📝 原始识别文本</h2>
        <div class="raw-text"><%= @ocr_record.raw_text %></div>
      </div>
    <% end %>
  </div>

  <%
    def confidence_class(score)
      if score >= 0.8
        'confidence-high'
      elsif score >= 0.5
        'confidence-medium'
      else
        'confidence-low'
      end
    end
  %>
</body>
</html>
