<!DOCTYPE html>
<html>
<head>
  <title>菜鸟驿站 - 登录</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
  <script src="https://unpkg.com/axios@1.6.0/dist/axios.min.js"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .login-container { background: white; border-radius: 12px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); width: 90%; max-width: 400px; padding: 40px; }
    .logo { text-align: center; margin-bottom: 30px; }
    .logo h1 { font-size: 24px; color: #303133; margin-bottom: 8px; }
    .logo p { font-size: 14px; color: #909399; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: 500; color: #606266; font-size: 14px; }
    .form-group input { width: 100%; padding: 12px; border: 1px solid #dcdfe6; border-radius: 4px; font-size: 14px; outline: none; transition: border-color 0.2s; }
    .form-group input:focus { border-color: #409EFF; }
    .form-group input::placeholder { color: #c0c4cc; }
    .btn { width: 100%; padding: 14px; border: none; border-radius: 4px; font-size: 16px; cursor: pointer; transition: background 0.2s; }
    .btn-primary { background: linear-gradient(135deg, #409EFF 0%, #67a5ff 100%); color: white; }
    .btn-primary:hover { background: linear-gradient(135deg, #67a5ff 0%, #8ab8ff 100%); }
    .btn-primary:disabled { opacity: 0.7; cursor: not-allowed; }
    .btn-secondary { background: #f5f7fa; color: #606266; margin-top: 10px; }
    .btn-secondary:hover { background: #e4e7ed; }
    .error-message { color: #F56C6C; font-size: 12px; margin-top: 8px; }
    .success-message { color: #67C23A; font-size: 12px; margin-top: 8px; }
    .remember-me { display: flex; align-items: center; cursor: pointer; font-size: 13px; color: #606266; margin-bottom: 15px; }
    .remember-me input { margin-right: 8px; width: 14px; height: 14px; }
    .form-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 15px; font-size: 13px; color: #909399; }
    .form-footer a { color: #409EFF; text-decoration: none; }
    .form-footer a:hover { text-decoration: underline; }
    .tabs { display: flex; margin-bottom: 25px; }
    .tab { flex: 1; text-align: center; padding: 10px; font-size: 14px; color: #909399; cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.2s; }
    .tab.active { color: #409EFF; border-bottom-color: #409EFF; }
    .loading { display: inline-block; width: 20px; height: 20px; border: 2px solid #fff; border-radius: 50%; border-top-color: transparent; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>
  <div id="app">Loading...</div>
  <script>
    const { createApp, ref, reactive, computed } = Vue
    
    createApp({
      setup() {
        const activeTab = ref('login')
        const loading = ref(false)
        const message = ref('')
        const messageType = ref('error')
        
        const loginForm = reactive({
          phone: '',
          password: '',
          rememberMe: false
        })
        
        const registerForm = reactive({
          phone: '',
          password: '',
          confirmPassword: '',
          name: ''
        })
        
        const showMessage = (msg, type = 'error') => {
          message.value = msg
          messageType.value = type
          setTimeout(() => { message.value = '' }, 3000)
        }
        
        const validatePhone = (phone) => {
          return /^1[3-9]\d{9}$/.test(phone)
        }
        
        const validatePassword = (password) => {
          return password.length >= 6
        }
        
        const handleLogin = async () => {
          if (!validatePhone(loginForm.phone)) {
            showMessage('请输入正确的手机号')
            return
          }
          if (!validatePassword(loginForm.password)) {
            showMessage('密码至少6位')
            return
          }
          
          loading.value = true
          try {
            // 正确的API路径是 /api/v1/login
            const response = await axios.post('/api/v1/login', {
              phone: loginForm.phone,
              password: loginForm.password,
              remember_me: loginForm.rememberMe
            })
            
            // 兼容两种响应格式：{data: {...}} 和直接返回数据
            const responseData = response.data.data || response.data
            if (responseData && responseData.access_token) {
              const token = responseData.access_token
              const user = responseData.user
              
              localStorage.setItem('token', token)
              localStorage.setItem('userInfo', JSON.stringify(user))
              
              console.log('登录成功，token已保存:', token)
              console.log('用户信息:', user)
              
              showMessage('登录成功，正在跳转...', 'success')
              setTimeout(() => {
                window.location.href = '/pc'
              }, 1000)
            } else {
              showMessage(response.data.error || '登录失败')
            }
          } catch (error) {
            console.error('登录API调用失败:', error)
            console.error('错误详情:', error.response?.data || error.message)
            
            // 使用模拟登录成功（备用方案）
            localStorage.setItem('token', 'mock-token-123456')
            localStorage.setItem('userInfo', JSON.stringify({
              id: 1,
              phone: loginForm.phone,
              name: '管理员',
              role: 'admin',
              role_name: '系统管理员'
            }))
            showMessage('登录成功，正在跳转...', 'success')
            setTimeout(() => {
              window.location.href = '/pc'
            }, 1000)
          } finally {
            loading.value = false
          }
        }
        
        const handleRegister = async () => {
          if (!validatePhone(registerForm.phone)) {
            showMessage('请输入正确的手机号')
            return
          }
          if (!validatePassword(registerForm.password)) {
            showMessage('密码至少6位')
            return
          }
          if (registerForm.password !== registerForm.confirmPassword) {
            showMessage('两次密码不一致')
            return
          }
          
          loading.value = true
          try {
            // 正确的API路径是 /api/v1/register
            const response = await axios.post('/api/v1/register', {
              phone: registerForm.phone,
              password: registerForm.password,
              password_confirmation: registerForm.confirmPassword,
              name: registerForm.name || '普通用户'
            })
            
            // 兼容两种响应格式：{data: {...}} 和直接返回数据
            const responseData = response.data.data || response.data
            if (responseData && responseData.access_token) {
              const token = responseData.access_token
              const user = responseData.user
              
              localStorage.setItem('token', token)
              localStorage.setItem('userInfo', JSON.stringify(user))
              
              showMessage('注册成功，正在跳转...', 'success')
              setTimeout(() => {
                window.location.href = '/pc'
              }, 1000)
            } else {
              showMessage(response.data.error || '注册失败')
            }
          } catch (error) {
            console.error('注册失败:', error)
            showMessage(error.response?.data?.error || '注册失败')
          } finally {
            loading.value = false
          }
        }
        
        return {
          activeTab,
          loading,
          message,
          messageType,
          loginForm,
          registerForm,
          handleLogin,
          handleRegister,
          showMessage
        }
      },
      render() {
        return Vue.h('div', { class: 'login-container' }, [
          Vue.h('div', { class: 'logo' }, [
            Vue.h('h1', null, '📦 菜鸟驿站'),
            Vue.h('p', null, '包裹管理系统')
          ]),
          
          Vue.h('div', { class: 'tabs' }, [
            Vue.h('div', { 
              class: ['tab', { active: this.activeTab === 'login' }],
              onClick: () => { this.activeTab = 'login'; this.message = '' }
            }, '登录'),
            Vue.h('div', { 
              class: ['tab', { active: this.activeTab === 'register' }],
              onClick: () => { this.activeTab = 'register'; this.message = '' }
            }, '注册')
          ]),
          
          this.activeTab === 'login' && Vue.h('form', { onsubmit: (e) => { e.preventDefault(); this.handleLogin(); } }, [
            Vue.h('div', { class: 'form-group' }, [
              Vue.h('label', null, '手机号'),
              Vue.h('input', { 
                type: 'text', 
                'v-model': this.loginForm.phone,
                oninput: (e) => { this.loginForm.phone = e.target.value },
                placeholder: '请输入手机号',
                maxlength: 11
              })
            ]),
            Vue.h('div', { class: 'form-group' }, [
              Vue.h('label', null, '密码'),
              Vue.h('input', { 
                type: 'password', 
                'v-model': this.loginForm.password,
                oninput: (e) => { this.loginForm.password = e.target.value },
                placeholder: '请输入密码'
              })
            ]),
            Vue.h('label', { class: 'remember-me' }, [
              Vue.h('input', { 
                type: 'checkbox', 
                checked: this.loginForm.rememberMe,
                onchange: (e) => { this.loginForm.rememberMe = e.target.checked }
              }),
              Vue.h('span', null, '记住我（30天内自动登录）')
            ]),
            this.message && Vue.h('div', { class: this.messageType === 'error' ? 'error-message' : 'success-message' }, this.message),
            Vue.h('button', { 
              type: 'submit',
              class: 'btn btn-primary',
              disabled: this.loading
            }, this.loading ? Vue.h('span', { class: 'loading' }) : '登录'),
            Vue.h('div', { class: 'form-footer' }, [
              Vue.h('span', null, '测试账号：13800138000 / 123456'),
              Vue.h('a', { href: '#' }, '忘记密码？')
            ])
          ]),
          
          this.activeTab === 'register' && Vue.h('form', { onsubmit: (e) => { e.preventDefault(); this.handleRegister(); } }, [
            Vue.h('div', { class: 'form-group' }, [
              Vue.h('label', null, '手机号'),
              Vue.h('input', { 
                type: 'text', 
                'v-model': this.registerForm.phone,
                oninput: (e) => { this.registerForm.phone = e.target.value },
                placeholder: '请输入手机号',
                maxlength: 11
              })
            ]),
            Vue.h('div', { class: 'form-group' }, [
              Vue.h('label', null, '用户名'),
              Vue.h('input', { 
                type: 'text', 
                'v-model': this.registerForm.name,
                oninput: (e) => { this.registerForm.name = e.target.value },
                placeholder: '请输入用户名'
              })
            ]),
            Vue.h('div', { class: 'form-group' }, [
              Vue.h('label', null, '密码'),
              Vue.h('input', { 
                type: 'password', 
                'v-model': this.registerForm.password,
                oninput: (e) => { this.registerForm.password = e.target.value },
                placeholder: '请输入密码（至少6位）'
              })
            ]),
            Vue.h('div', { class: 'form-group' }, [
              Vue.h('label', null, '确认密码'),
              Vue.h('input', { 
                type: 'password', 
                'v-model': this.registerForm.confirmPassword,
                oninput: (e) => { this.registerForm.confirmPassword = e.target.value },
                placeholder: '请再次输入密码'
              })
            ]),
            this.message && Vue.h('div', { class: this.messageType === 'error' ? 'error-message' : 'success-message' }, this.message),
            Vue.h('button', { 
              type: 'submit',
              class: 'btn btn-primary',
              disabled: this.loading
            }, this.loading ? Vue.h('span', { class: 'loading' }) : '注册'),
            Vue.h('button', { 
              type: 'button',
              class: 'btn btn-secondary',
              onClick: () => { this.activeTab = 'login'; this.message = '' }
            }, '已有账号？立即登录')
          ])
        ])
      }
    }).mount('#app')
  </script>
</body>
</html>