        const triggerOcrUpload = () => {
          ocrFileInput.value?.click()
        }
        
        const performOCR = async (event) => {
          const file = event.target.files[0]
          if (!file) return
          
          // 设置图片预览
          const reader = new FileReader()
          reader.onload = (e) => {
            ocrImage.value = e.target.result
          }
          reader.readAsDataURL(file)
          
          ocrLoading.value = true
          try {
            await new Promise(resolve => setTimeout(resolve, 2000))
            
            // 调用后端OCR API进行识别
            const token = localStorage.getItem('token')
            const formData = new FormData()
            formData.append('image', file)
            
            const response = await axios.post('/api/v1/ocr/recognize', formData, {
              headers: { 
                Authorization: `Bearer ${token}`,
                'Content-Type': 'multipart/form-data'
              }
            })
            
            // axios拦截器会自动提取data.data，所以需要检查原始响应
            const originalData = response.data
            const hasSuccessField = originalData.success !== undefined
            
            // 根据响应格式判断
            if (hasSuccessField) {
              // 原始格式：{ success: true, data: {...} }
              if (originalData.success && originalData.data) {
                ocrResult.value = {
                  tracking_number: originalData.data.tracking_number || '',
                  recipient_name: originalData.data.recipient_name || '',
                  recipient_phone: originalData.data.recipient_phone || '',
                  courier_company: originalData.data.courier_company || '',
                  address: originalData.data.address || ''
                }
                ocrQuality.value = originalData.quality || null
                ocrConfidence.value = originalData.confidence || null
                addToOCRHistory({ ...ocrResult.value, quality: ocrQuality.value, confidence: ocrConfidence.value })
                toast.success('识别成功')
              } else {
                const errorMsg = originalData.error || '识别失败'
                console.error('❌ OCR识别失败:', originalData)
                toast.error(`识别失败: ${errorMsg}`)
              }
            } else {
              // 拦截器处理后的格式：{ tracking_number: ..., recipient_name: ... }
              if (originalData.tracking_number || originalData.recipient_name) {
                ocrResult.value = {
                  tracking_number: originalData.tracking_number || '',
                  recipient_name: originalData.recipient_name || '',
                  recipient_phone: originalData.recipient_phone || '',
                  courier_company: originalData.courier_company || '',
                  address: originalData.address || ''
                }
                ocrQuality.value = response.meta?.quality || null
                ocrConfidence.value = response.meta?.confidence || null
                addToOCRHistory({ ...ocrResult.value, quality: ocrQuality.value, confidence: ocrConfidence.value })
                toast.success('识别成功')
              } else {
                console.error('❌ OCR识别失败: 数据为空', originalData)
                toast.error('识别失败: 未识别到有效数据')
              }
            }
            
            showOcrModal.value = false
            activeMenu.value = 'ocr'
            window.history.pushState({}, '', '/pc/ocr')
          } catch (error) {
            console.error('OCR识别异常:', error)
            toast.error('识别失败，请重试')
          } finally {
            ocrLoading.value = false
            // 重置文件输入，允许重复选择同一文件
            if (event.target) {
              event.target.value = ''
            }
          }
