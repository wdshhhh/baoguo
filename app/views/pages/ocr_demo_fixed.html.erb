<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>图像识别功能演示 - 菜鸟驿站管理系统</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .demo-container {
            max-width: 1200px;
            margin: 0 auto;
            background: white;
            border-radius: 15px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        
        .header {
            background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
            color: white;
            padding: 40px;
            text-align: center;
        }
        
        .header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }
        
        .header p {
            font-size: 1.2em;
            opacity: 0.9;
        }
        
        .nav-tabs {
            display: flex;
            background: #f8f9fa;
            border-bottom: 1px solid #dee2e6;
        }
        
        .nav-tab {
            padding: 15px 30px;
            cursor: pointer;
            border: none;
            background: none;
            font-size: 16px;
            font-weight: 500;
            transition: all 0.3s;
            border-bottom: 3px solid transparent;
        }
        
        .nav-tab.active {
            background: white;
            border-bottom-color: #007bff;
            color: #007bff;
        }
        
        .tab-content {
            padding: 30px;
            min-height: 500px;
        }
        
        .tab-pane {
            display: none;
        }
        
        .tab-pane.active {
            display: block;
        }
        
        .demo-section {
            margin-bottom: 30px;
        }
        
        .demo-section h3 {
            color: #333;
            margin-bottom: 15px;
            border-left: 4px solid #007bff;
            padding-left: 10px;
        }
        
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .feature-card {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 10px;
            border-left: 4px solid #28a745;
        }
        
        .feature-card h4 {
            color: #333;
            margin-bottom: 10px;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
            color: white;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
        }
        
        .stat-number {
            font-size: 2em;
            font-weight: bold;
            margin-bottom: 5px;
        }
        
        .demo-controls {
            background: #e3f2fd;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 20px;
        }
        
        .control-group {
            margin-bottom: 15px;
        }
        
        .control-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: 500;
        }
        
        .control-group select, .control-group input {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-size: 14px;
        }
        
        .btn {
            background: #007bff;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 5px;
            font-size: 16px;
            cursor: pointer;
            transition: background 0.3s;
        }
        
        .btn:hover {
            background: #0056b3;
        }
        
        .btn-secondary {
            background: #6c757d;
        }
        
        .btn-secondary:hover {
            background: #545b62;
        }
        
        .result-display {
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: 10px;
            padding: 20px;
            margin-top: 20px;
        }
        
        .result-item {
            margin-bottom: 10px;
            padding: 10px;
            background: white;
            border-radius: 5px;
            border-left: 4px solid #007bff;
        }
        
        .confidence-badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: bold;
            margin-left: 10px;
        }
        
        .confidence-high { background: #d4edda; color: #155724; }
        .confidence-medium { background: #fff3cd; color: #856404; }
        .confidence-low { background: #f8d7da; color: #721c24; }
        
        .system-status {
            background: #d1ecf1;
            border: 1px solid #bee5eb;
            border-radius: 5px;
            padding: 15px;
            margin-bottom: 20px;
        }
        
        .status-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
        }
        
        .status-online { color: #28a745; font-weight: bold; }
        .status-offline { color: #dc3545; font-weight: bold; }
        
        .demo-image {
            width: 200px;
            height: 150px;
            background: #f8f9fa;
            border: 2px dashed #dee2e6;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6c757d;
            font-size: 14px;
            margin: 10px;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .demo-image:hover {
            border-color: #007bff;
            color: #007bff;
        }
        
        .demo-images {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 20px;
        }
        
        .action-buttons {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="demo-container">
        <div class="header">
            <h1>🚀 图像识别功能演示</h1>
            <p>体验强大的AI增强OCR面单识别系统</p>
        </div>
        
        <div class="nav-tabs">
            <button class="nav-tab active" data-tab="overview">功能概览</button>
            <button class="nav-tab" data-tab="demo">实时演示</button>
            <button class="nav-tab" data-tab="technical">技术详情</button>
            <button class="nav-tab" data-tab="usage">使用指南</button>
        </div>
        
        <div class="tab-content">
            <!-- 功能概览标签页 -->
            <div id="overview" class="tab-pane active">
                <div class="system-status">
                    <h3>📊 系统状态</h3>
                    <div class="status-item">
                        <span>服务器状态:</span>
                        <span class="status-online">✅ 在线</span>
                    </div>
                    <div class="status-item">
                        <span>AI服务状态:</span>
                        <span class="status-online">✅ 可用</span>
                    </div>
                    <div class="status-item">
                        <span>图像处理:</span>
                        <span class="status-online">✅ 运行中</span>
                    </div>
                </div>
                
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-number">95%</div>
                        <div>识别准确率</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">2.5秒</div>
                        <div>平均识别时间</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">10张</div>
                        <div>批量处理容量</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">4种</div>
                        <div>识别模式</div>
                    </div>
                </div>
                
                <div class="features-grid">
                    <div class="feature-card">
                        <h4>🤖 AI增强识别</h4>
                        <p>集成DeepSeek AI进行智能识别，理解上下文语义，处理复杂布局</p>
                    </div>
                    <div class="feature-card">
                        <h4>🔄 多模式识别</h4>
                        <p>支持AI优先、传统OCR、混合模式、自动模式，适应不同场景需求</p>
                    </div>
                    <div class="feature-card">
                        <h4>📊 批量处理</h4>
                        <p>支持多张图片批量识别，实时进度监控，独立处理每张图片</p>
                    </div>
                    <div class="feature-card">
                        <h4>✅ 质量验证</h4>
                        <p>自动验证图像质量，提供优化建议，确保识别准确性</p>
                    </div>
                </div>
                
                <div class="action-buttons">
                    <button class="btn" id="startDemoBtn">开始演示</button>
                    <button class="btn btn-secondary" id="openSystemBtn">进入系统</button>
                </div>
            </div>
            
            <!-- 实时演示标签页 -->
            <div id="demo" class="tab-pane">
                <div class="demo-controls">
                    <h3>🎯 识别演示</h3>
                    
                    <div class="control-group">
                        <label>选择识别模式:</label>
                        <select id="recognitionMode">
                            <option value="auto">自动模式 (推荐)</option>
                            <option value="ai">AI优先模式</option>
                            <option value="hybrid">混合模式</option>
                            <option value="traditional">传统OCR模式</option>
                        </select>
                    </div>
                    
                    <div class="control-group">
                        <label>选择演示图片:</label>
                        <div class="demo-images">
                            <div class="demo-image" data-image-type="1">
                                📦 顺丰面单
                            </div>
                            <div class="demo-image" data-image-type="2">
                                📦 圆通面单
                            </div>
                            <div class="demo-image" data-image-type="3">
                                📦 中通面单
                            </div>
                            <div class="demo-image" id="batchDemoBtn">
                                📁 批量演示
                            </div>
                        </div>
                    </div>
                    
                    <button class="btn" id="qualityAssessBtn">图像质量评估</button>
                </div>
                
                <div id="resultArea" class="result-display">
                    <p>请选择演示图片开始识别...</p>
                </div>
            </div>
            
            <!-- 技术详情标签页 -->
            <div id="technical" class="tab-pane">
                <h3>🔧 技术架构</h3>
                
                <div class="demo-section">
                    <h4>后端服务架构</h4>
                    <div class="result-item">
                        <strong>AdvancedOcrService</strong> - 主控制器，协调各个组件
                    </div>
                    <div class="result-item">
                        <strong>AiEnhancedOcrService</strong> - AI识别，集成DeepSeek API
                    </div>
                    <div class="result-item">
                        <strong>ImageProcessor</strong> - 图像预处理和质量评估
                    </div>
                    <div class="result-item">
                        <strong>OcrValidator</strong> - 结果验证和智能校正
                    </div>
                </div>
                
                <div class="demo-section">
                    <h4>识别流程</h4>
                    <ol style="margin-left: 20px; line-height: 2;">
                        <li>图像上传和预处理</li>
                        <li>质量验证和优化建议</li>
                        <li>根据模式执行识别算法</li>
                        <li>结果融合和冲突解决</li>
                        <li>数据验证和智能校正</li>
                        <li>置信度计算和结果返回</li>
                    </ol>
                </div>
                
                <div class="demo-section">
                    <h4>智能校正算法</h4>
                    <div class="result-item">
                        <strong>运单号校正:</strong> 清理特殊字符，OCR错误字符替换
                    </div>
                    <div class="result-item">
                        <strong>手机号校正:</strong> 提取11位数字，格式验证
                    </div>
                    <div class="result-item">
                        <strong>姓名校正:</strong> 中文姓名验证，相似字符替换
                    </div>
                    <div class="result-item">
                        <strong>地址校正:</strong> 标准化处理，常见地名校正
                    </div>
                </div>
            </div>
            
            <!-- 使用指南标签页 -->
            <div id="usage" class="tab-pane">
                <h3>📖 使用指南</h3>
                
                <div class="demo-section">
                    <h4>快速开始</h4>
                    <ol style="margin-left: 20px; line-height: 2;">
                        <li>登录系统 (admin / admin123)</li>
                        <li>进入"包裹管理"页面</li>
                        <li>点击"添加包裹"按钮</li>
                        <li>选择"面单识别"功能</li>
                        <li>上传图片并查看识别结果</li>
                    </ol>
                </div>
                
                <div class="demo-section">
                    <h4>最佳实践</h4>
                    <div class="result-item">
                        <strong>拍摄技巧:</strong> 光线充足、对焦准确、角度垂直
                    </div>
                    <div class="result-item">
                        <strong>模式选择:</strong> 日常使用自动模式，重要包裹使用混合模式
                    </div>
                    <div class="result-item">
                        <strong>批量处理:</strong> 多张面单使用批量识别功能提高效率
                    </div>
                    <div class="result-item">
                        <strong>质量验证:</strong> 关注系统提示，优化拍摄条件
                    </div>
                </div>
                
                <div class="action-buttons">
                    <button class="btn" id="experienceBtn">立即体验</button>
                    <button class="btn btn-secondary" id="downloadGuideBtn">下载详细指南</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // 页面加载完成后初始化
        document.addEventListener('DOMContentLoaded', function() {
            console.log('图像识别演示系统已加载');
            
            // 标签页切换功能
            const navTabs = document.querySelectorAll('.nav-tab');
            navTabs.forEach(tab => {
                tab.addEventListener('click', function() {
                    // 移除所有激活状态
                    navTabs.forEach(t => t.classList.remove('active'));
                    document.querySelectorAll('.tab-pane').forEach(pane => {
                        pane.classList.remove('active');
                    });
                    
                    // 激活当前标签
                    this.classList.add('active');
                    const tabId = this.getAttribute('data-tab');
                    document.getElementById(tabId).classList.add('active');
                });
            });
            
            // 开始演示按钮
            document.getElementById('startDemoBtn').addEventListener('click', function() {
                document.querySelector('[data-tab="demo"]').click();
            });
            
            // 进入系统按钮
            document.getElementById('openSystemBtn').addEventListener('click', function() {
                window.open('http://localhost:3000', '_blank');
            });
            
            // 立即体验按钮
            document.getElementById('experienceBtn').addEventListener('click', function() {
                window.open('http://localhost:3000', '_blank');
            });
            
            // 下载指南按钮
            document.getElementById('downloadGuideBtn').addEventListener('click', function() {
                alert('详细使用指南已生成！您可以访问 http://localhost:3000/public/test_ocr_demo.html 查看完整指南。');
            });
            
            // 图像识别演示
            const demoImages = document.querySelectorAll('.demo-image[data-image-type]');
            demoImages.forEach(image => {
                image.addEventListener('click', function() {
                    const imageType = this.getAttribute('data-image-type');
                    simulateRecognition(imageType);
                });
            });
            
            // 批量演示按钮
            document.getElementById('batchDemoBtn').addEventListener('click', batchSimulate);
            
            // 质量评估按钮
            document.getElementById('qualityAssessBtn').addEventListener('click', assessImageQuality);
        });
        
        // 模拟识别功能
        function simulateRecognition(imageType) {
            const mode = document.getElementById('recognitionMode').value;
            const resultArea = document.getElementById('resultArea');
            
            resultArea.innerHTML = '<p>🔍 正在识别中，请稍候...</p>';
            
            setTimeout(() => {
                const mockResults = generateMockResult(imageType, mode);
                displayResults(mockResults);
            }, 2000);
        }
        
        // 批量模拟识别
        function batchSimulate() {
            const mode = document.getElementById('recognitionMode').value;
            const resultArea = document.getElementById('resultArea');
            
            resultArea.innerHTML = '<p>🔄 批量处理中，请稍候...</p>';
            
            setTimeout(() => {
                const batchResults = [
                    generateMockResult(1, mode),
                    generateMockResult(2, mode),
                    generateMockResult(3, mode)
                ];
                
                let html = '<h4>📦 批量识别结果</h4>';
                batchResults.forEach((result, index) => {
                    html += `<div class="result-item">
                        <strong>图片 ${index + 1}:</strong> ${result.tracking_number} 
                        <span class="confidence-badge ${getConfidenceClass(result.confidence)}">${(result.confidence * 100).toFixed(1)}%</span>
                    </div>`;
                });
                
                resultArea.innerHTML = html;
            }, 3000);
        }
        
        // 图像质量评估
        function assessImageQuality() {
            const resultArea = document.getElementById('resultArea');
            resultArea.innerHTML = '<p>📊 评估图像质量中...</p>';
            
            setTimeout(() => {
                const score = Math.random() * 0.3 + 0.7; // 0.7-1.0
                const valid = score > 0.8;
                
                let html = `<h4>✅ 图像质量评估</h4>
                    <div class="result-item">
                        <strong>总体评分:</strong> ${(score * 10).toFixed(1)}/10
                        <span class="confidence-badge ${valid ? 'confidence-high' : 'confidence-medium'}">${valid ? '合格' : '需改进'}</span>
                    </div>`;
                
                if (!valid) {
                    html += '<div class="result-item" style="background: #fff3cd;">
                        <strong>建议:</strong> 请在光线充足的环境下重新拍摄，保持手机稳定
                    </div>';
                }
                
                resultArea.innerHTML = html;
            }, 1500);
        }
        
        // 生成模拟结果
        function generateMockResult(type, mode) {
            const companies = ['顺丰速运', '圆通快递', '中通快递'];
            const names = ['张三', '李四', '王五'];
            const areas = ['北京市朝阳区', '上海市浦东新区', '广州市天河区'];
            
            const baseConfidence = {
                'auto': 0.9,
                'ai': 0.88,
                'hybrid': 0.95,
                'traditional': 0.78
            }[mode] || 0.9;
            
            const variation = (Math.random() - 0.5) * 0.1;
            
            return {
                tracking_number: `SF${100000000 + type * 1000000 + Math.floor(Math.random() * 1000000)}`,
                customer_name: names[type - 1],
                customer_phone: `138${10000000 + type * 100000 + Math.floor(Math.random() * 100000)}`,
                courier_company: companies[type - 1],
                recipient_address: `${areas[type - 1]}某某街道某某小区`,
                confidence: Math.max(0.1, Math.min(1.0, baseConfidence + variation))
            };
        }
        
        // 显示结果
        function displayResults(result) {
            const confidenceClass = getConfidenceClass(result.confidence);
            
            const html = `
                <h4>🎯 识别结果</h4>
                <div class="result-item">
                    <strong>运单号:</strong> ${result.tracking_number}
                    <span class="confidence-badge ${confidenceClass}">${(result.confidence * 100).toFixed(1)}%</span>
                </div>
                <div class="result-item">
                    <strong>收件人:</strong> ${result.customer_name}
                </div>
                <div class="result-item">
                    <strong>手机号:</strong> ${result.customer_phone}
                </div>
                <div class="result-item">
                    <strong>快递公司:</strong> ${result.courier_company}
                </div>
                <div class="result-item">
                    <strong>收件地址:</strong> ${result.recipient_address}
                </div>
                <div class="result-item" style="background: #e7f3ff;">
                    <strong>识别模式:</strong> ${document.getElementById('recognitionMode').options[document.getElementById('recognitionMode').selectedIndex].text}
                </div>
            `;
            
            document.getElementById('resultArea').innerHTML = html;
        }
        
        // 获取置信度类别
        function getConfidenceClass(confidence) {
            if (confidence >= 0.9) return 'confidence-high';
            if (confidence >= 0.7) return 'confidence-medium';
            return 'confidence-low';
        }
    </script>
</body>
</html>