    // 未捕获的Promise错误
    window.addEventListener('unhandledrejection', function(event) {
      console.error('🚨 未捕获的Promise错误:', event.reason);
      alert('系统异常，请刷新页面重试\n\n错误详情: ' + (event.reason?.message || '未知错误'));
      event.preventDefault();
    });

    // JavaScript运行时错误
    window.addEventListener('error', function(event) {
      console.error('🚨 JavaScript错误:', event.message, 'at line', event.lineno, 'column', event.colno);
      console.error('错误来源:', event.filename);
      console.error('错误对象:', event.error);
      // 只有在不是Script error时才显示alert，避免重复提示
      if (event.message !== 'Script error.' || event.filename) {
        alert('系统异常，请刷新页面重试\n\n错误: ' + event.message + '\n文件: ' + (event.filename || '未知'));
      }
    });

    // ========== Axios全局配置 ==========
    axios.interceptors.response.use(
      response => {
        // 兼容不同的响应格式
        const data = response.data;
        if (data && data.data !== undefined) {
          return { ...response, data: data.data, meta: data.meta };
        }
        return response;
      },
      error => {
        console.error('🚨 请求失败:', error.response?.status, error.response?.data);
        
        // 如果是认证错误，重定向到登录页
        if (error.response?.status === 401) {
          localStorage.removeItem('token');
          localStorage.removeItem('userInfo');
          alert('登录已失效，请重新登录');
          setTimeout(() => {
            window.location.href = '/login';
          }, 500);
        }
        
        return Promise.reject(error);
      }
    );

