        </div>
      </div>
      
      <!-- 消息区域 -->
      <div class="ai-chat-messages" ref="aiChatMessagesRef">
        <div v-if="aiMessages.length === 0" style="text-align: center; padding: 40px 20px; color: #909399;">
          <div style="font-size: 48px; margin-bottom: 15px;">👋</div>
          <p>您好！我是驿站小助手</p>
          <p style="font-size: 13px; margin-top: 8px;">有什么可以帮您？</p>
        </div>
        
        <div v-for="(msg, index) in aiMessages" :key="index" :class="['ai-message', msg.role]">
          <div class="avatar">{{ msg.role === 'user' ? '👤' : '🤖' }}</div>
          <div>
            <div class="bubble">
              <div v-if="msg.packages && msg.packages.length > 0">
                <div v-html="formatMessage(msg.content)"></div>
                <div v-for="pkg in msg.packages" :key="pkg.id" class="ai-package-card">
                  <div class="package-row"><span class="package-label">运单号</span><span class="package-value">{{ pkg.tracking_number }}</span></div>
                  <div class="package-row"><span class="package-label">收件人</span><span class="package-value">{{ pkg.recipient_name }}</span></div>
                  <div class="package-row"><span class="package-label">快递公司</span><span class="package-value">{{ pkg.courier_company }}</span></div>
                  <div class="package-row"><span class="package-label">状态</span><span :class="['package-value', 'status-' + pkg.status]">{{ getStatusLabel(pkg.status) }}</span></div>
                  <div v-if="pkg.pickup_code" class="package-row"><span class="package-label">取件码</span><span class="package-value">{{ pkg.pickup_code }}</span></div>
                </div>
              </div>
              <div v-else>
                <div v-html="formatMessage(msg.content)"></div>
              </div>
            </div>
            <div class="time">{{ msg.time }}</div>
          </div>
        </div>
        
        <div v-if="aiChatProcessing" class="ai-loading"><span></span></div>
      </div>
      
