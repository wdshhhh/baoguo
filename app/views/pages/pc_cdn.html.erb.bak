                                if (e.target.checked) {
                                  selectedExceptions.value.push(exc)
                                } else {
                                  selectedExceptions.value = selectedExceptions.value.filter(e => e.id !== exc.id)
                                }
                              },
                              style: 'cursor:pointer;'
                            })
